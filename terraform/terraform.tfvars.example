# GCP Project Configuration
project_id = "your-gcp-project-id"
region     = "us-central1"

# Cluster Configuration
cluster_name       = "clusterkit"
kubernetes_version = "1.28"

# Networking
static_ip_name = "clusterkit-ingress-ip"

# Environment
environment         = "dev"
deletion_protection = true

# Domains (Origin CA cert domains get Full Strict SSL on Cloudflare)
origin_ca_domains  = ["torale.ai", "bananagraph.com", "a2aregistry.org", "repowire.io"]
cloudflare_domains = ["torale.ai", "bananagraph.com", "a2aregistry.org", "repowire.io", "feedforward.space"]

# Cloud SQL
cloudsql_instance_name = "clusterkit-db"
